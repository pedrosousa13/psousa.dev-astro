---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main id="main-content">
    <div class="not-found-wrapper">
      <p class="query-line">
        <span class="dim">psousa.dev=#</span> select * from pages where slug = ?;
      </p>
      <h1 aria-label="404 Not Found">404</h1>
      <p class="dim">-- 0 rows. nothing here.</p>
      <LinkButton href="/" className="back-home-link"
        >-&gt; back home</LinkButton
      >
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @reference "../styles/base.css";

  #main-content {
    @apply mx-auto flex max-w-3xl flex-1 items-center justify-center;
  }
  .not-found-wrapper {
    @apply mb-14 flex flex-col items-center justify-center gap-3 text-center;
  }
  .query-line {
    @apply text-skin-dim text-sm sm:text-base;
  }
  .dim {
    @apply text-skin-dim;
  }
  .not-found-wrapper h1 {
    @apply text-skin-base my-2 text-7xl font-bold sm:text-8xl;
  }
  .back-home-link {
    @apply text-skin-dim hover:text-skin-accent mt-2 text-lg transition-colors duration-[120ms];
  }
</style>
