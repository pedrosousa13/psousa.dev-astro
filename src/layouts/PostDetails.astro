---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Tag from "@components/Tag.astro";
import Datetime from "@components/Datetime";
import Comments from "@components/Comments";
import { render, type CollectionEntry } from "astro:content";
import { slugifyStr } from "@utils/slugify";
import ShareLinks from "@components/ShareLinks.astro";
import { getCollection } from "astro:content";
import postFilter from "@utils/postFilter";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  readingTime,
  pubDatetime,
  modDatetime,
  tags,
} = post.data;

const { Content } = await render(post);

const contentStoreSeries = [
  {
    part: 1,
    slug: "content-store-part-1",
    title: "Stop fetching what you already have",
  },
  {
    part: 2,
    slug: "content-store-part-2",
    title: "Keeping a copy you can trust",
  },
  {
    part: 3,
    slug: "content-store-part-3",
    title: "The read side",
  },
  {
    part: 4,
    slug: "content-store-part-4",
    title: "The fun stuff",
  },
];

const publishedPostSlugs = new Set(
  (await getCollection("blog", postFilter)).map(post => post.id)
);
const currentSeriesPart = contentStoreSeries.find(
  item => item.slug === post.id
);
const nextSeriesPart =
  currentSeriesPart &&
  contentStoreSeries.find(
    item =>
      item.part === currentSeriesPart.part + 1 &&
      publishedPostSlugs.has(item.slug)
  );
const isContentStorePost = Boolean(currentSeriesPart);

const ogImageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src;
const ogUrl = new URL(
  ogImageUrl ?? `/posts/${slugifyStr(title)}/index.png`,
  Astro.url.origin
).href;

const layoutProps = {
  title,
  author,
  description,
  pubDatetime,
  readingTime,
  modDatetime,
  canonicalURL,
  ogImage: ogUrl,
  scrollSmooth: true,
};
---

<Layout {...layoutProps}>
  <Header />
  <div class="mx-auto flex w-full max-w-3xl justify-start px-2">
    <button
      class="nav-text-button focus-outline mt-8 mb-2"
      onclick="history.back()"
    >
      &lt;- back
    </button>
  </div>
  <main id="main-content">
    <h1 class="post-title">{title}</h1>
    <p class="post-meta">
      -- <Datetime pubDatetime={pubDatetime} modDatetime={modDatetime} /> · {
        readingTime
      }
    </p>
    {
      isContentStorePost && currentSeriesPart && (
        <aside class="series-rail" aria-label="The content store series">
          <p class="series-kicker">
            The content store · part {currentSeriesPart.part} of{" "}
            {contentStoreSeries.length}
          </p>
          <ol class="series-list">
            {contentStoreSeries.map(item => {
              const published = publishedPostSlugs.has(item.slug);
              const isCurrent = item.slug === post.id;

              return (
                <li class={isCurrent ? "current" : ""}>
                  <span class="series-index">
                    {String(item.part).padStart(2, "0")}
                  </span>
                  {published ? (
                    <a href={`/posts/${item.slug}/`}>{item.title}</a>
                  ) : (
                    <span>{item.title}</span>
                  )}
                </li>
              );
            })}
          </ol>
        </aside>
      )
    }
    <article
      id="article"
      role="article"
      class="prose article-prose mx-auto mt-8 max-w-3xl"
    >
      <Content />
    </article>
    {
      nextSeriesPart && (
        <nav
          class="series-next"
          aria-label="Next article in The content store series"
        >
          <span>Next in series</span>
          <a href={`/posts/${nextSeriesPart.slug}/`}>
            {String(nextSeriesPart.part).padStart(2, "0")} ·{" "}
            {nextSeriesPart.title}
          </a>
        </nav>
      )
    }

    <ul class="my-8 flex flex-wrap gap-x-4 gap-y-1">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} />)}
    </ul>

    <div
      class="flex flex-col-reverse items-center justify-between gap-6 sm:flex-row-reverse sm:items-end sm:gap-4"
    >
      <button
        id="back-to-top"
        class="nav-text-button focus-outline py-1 whitespace-nowrap"
      >
        top ^
      </button>

      <ShareLinks />
    </div>
    <Comments client:idle />
  </main>
  <Footer />
</Layout>

<style>
  @reference "../styles/base.css";

  main {
    @apply mx-auto w-full max-w-3xl px-4 pb-12;
  }
  .nav-text-button {
    @apply text-skin-dim hover:text-skin-accent text-sm transition-colors duration-[120ms];
  }
  .post-title {
    @apply text-skin-base text-[1.6rem] font-semibold;
  }
  .post-meta {
    @apply text-skin-dim my-2 text-sm;
  }
  .series-rail {
    @apply border-skin-line bg-skin-card/60 mt-8 border px-4 py-3;
  }
  .series-kicker {
    @apply text-skin-dim m-0 mb-3 text-sm;
  }
  .series-list {
    @apply m-0 grid list-none gap-2 p-0 sm:grid-cols-2;
  }
  .series-list li {
    @apply text-skin-dim flex gap-2 text-sm;
  }
  .series-list li.current,
  .series-list li.current .series-index {
    @apply text-skin-base;
  }
  .series-list a {
    @apply hover:text-skin-accent transition-colors duration-[120ms];
  }
  .series-index {
    @apply text-skin-sql-keyword shrink-0 tabular-nums;
  }
  .article-prose {
    counter-reset: article-section;
  }
  .article-prose > p:first-of-type {
    @apply text-[1.05rem] leading-[1.8];
  }
  .article-prose h2:not(#table-of-contents) {
    counter-increment: article-section;
    margin-top: 3rem;
  }
  .article-prose h2:not(#table-of-contents)::before {
    @apply text-skin-sql-keyword mr-3 text-sm font-normal tabular-nums;
    content: counter(article-section, decimal-leading-zero);
  }
  .series-next {
    @apply border-skin-line mx-auto mt-10 flex max-w-3xl flex-col gap-1 border-t pt-5 text-sm;
  }
  .series-next span {
    @apply text-skin-dim;
  }
  .series-next a {
    @apply text-skin-base hover:text-skin-accent transition-colors duration-[120ms];
  }
</style>

<script is:inline>
  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    let copyButtonLabel = "Copy";
    let codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (let codeBlock of codeBlocks) {
      let wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      let copyButton = document.createElement("button");
      copyButton.className =
        "copy-code absolute right-3 -top-3 border border-skin-line bg-skin-card px-2 py-1 font-mono text-[0.7rem] text-skin-dim";
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock.parentNode.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      let code = block.querySelector("code");
      let text = code.innerText;

      await navigator.clipboard.writeText(text);

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();
  document.addEventListener("astro:after-swap", attachCopyButtons);

  /** Scrolls the document to the top when
   * the "Back to Top" button is clicked. */
  function backToTop() {
    document.querySelector("#back-to-top")?.addEventListener("click", () => {
      document.body.scrollTop = 0; // For Safari
      document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE and Opera
    });
  }
  backToTop();
  document.addEventListener("astro:after-swap", backToTop);
</script>
