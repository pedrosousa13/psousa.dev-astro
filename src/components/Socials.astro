---
import { SOCIALS } from "@config";

export interface Props {
  centered?: boolean;
}

const { centered = false } = Astro.props;
---

<div class={`social-links ${centered ? "flex" : ""}`}>
  {
    SOCIALS.filter(social => social.active).map(social => (
      <a
        href={social.href}
        target="_blank"
        rel="noopener noreferrer"
        title={social.linkTitle}
        aria-label={social.linkTitle}
        class="social-link"
      >
        {social.name.toLowerCase()}
      </a>
    ))
  }
</div>

<style>
  @reference "../styles/base.css";

  .social-links {
    @apply flex-wrap justify-center gap-x-4 gap-y-1;
  }
  .social-link {
    @apply text-skin-dim hover:text-skin-accent transition-colors duration-[120ms];
  }
</style>
