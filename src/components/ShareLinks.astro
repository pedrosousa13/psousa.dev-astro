---
import LinkButton from "./LinkButton.astro";

const URL = Astro.url;

const shareLinks = [
  {
    name: "WhatsApp",
    href: "https://wa.me/?text=",
    linkTitle: `Share this post via WhatsApp`,
  },
  {
    name: "Facebook",
    href: "https://www.facebook.com/sharer.php?u=",
    linkTitle: `Share this post on Facebook`,
  },
  {
    name: "Twitter",
    href: "https://twitter.com/intent/tweet?url=",
    linkTitle: `Tweet this post`,
  },
  {
    name: "Telegram",
    href: "https://t.me/share/url?url=",
    linkTitle: `Share this post via Telegram`,
  },
  {
    name: "Pinterest",
    href: "https://pinterest.com/pin/create/button/?url=",
    linkTitle: `Share this post on Pinterest`,
  },
  {
    name: "Mail",
    href: "mailto:?subject=See%20this%20post&body=",
    linkTitle: `Share this post via email`,
  },
] as const;
---

<div class="social-icons">
  <span class="share-label">-- share:</span>
  <div class="share-list">
    {
      shareLinks.map(social => (
        <LinkButton
          href={`${social.href + URL}`}
          className="link-button"
          title={social.linkTitle}
        >
          {social.name.toLowerCase()}
        </LinkButton>
      ))
    }
  </div>
</div>

<style>
  @reference "../styles/base.css";

  .social-icons {
    @apply flex flex-col items-center gap-1 sm:flex-row sm:items-baseline sm:gap-2;
  }
  .share-label {
    @apply text-skin-dim text-sm;
  }
  .share-list {
    @apply flex flex-wrap items-center justify-center gap-3 sm:justify-start;
  }
  .link-button {
    @apply text-skin-dim hover:text-skin-accent text-sm transition-colors duration-[120ms];
  }
</style>
